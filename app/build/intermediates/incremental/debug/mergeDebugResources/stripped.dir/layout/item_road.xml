<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Health Score Indicator -->
        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="12dp">

            <View
                android:id="@+id/viewHealthIndicator"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_health_circle" />

            <TextView
                android:id="@+id/tvHealthScore"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="85"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white" />
        </FrameLayout>

        <!-- Road Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvRoadName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Road Name"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tvRoadType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PMGSY"
                    android:textSize="11sp"
                    android:textColor="@color/primary"
                    android:background="@drawable/bg_status_chip"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp" />

                <TextView
                    android:id="@+id/tvLength"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12.5 km"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginStart="8dp" />

                <TextView
                    android:id="@+id/tvReports"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 reports"
                    android:textSize="11sp"
                    android:textColor="@color/secondary"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
